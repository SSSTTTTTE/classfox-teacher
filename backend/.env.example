# v1.1.1 过渡说明：
# 课堂推理主链路将迁到本地 Ollama，以下 LLM_* 仅保留给历史兼容云端链路排障使用。
# 默认可留空，不再要求先准备云端 API Key。
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_SUMMARY_MODEL=
LLM_FALLBACK_MODEL=

# Local Ollama (v1.1.1 主链路)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_FINAL_SUMMARY_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=45
OLLAMA_MAX_TOKENS=1024
OLLAMA_TEMPERATURE=0.3
OLLAMA_REALTIME_SUMMARY_ENABLED=false
OLLAMA_REALTIME_SUMMARY_MODEL=qwen2.5:1.5b

# ASR mode: local | mock | dashscope | seed-asr
ASR_MODE=local

# DashScope Fun-ASR
DASHSCOPE_API_KEY=your_dashscope_api_key

# Seed-ASR
SEED_ASR_APP_KEY=your_seed_asr_app_key
SEED_ASR_ACCESS_KEY=your_seed_asr_access_key
SEED_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
SEED_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
